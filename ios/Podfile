# Uncomment this line to define a global platform for your project
platform :ios, '17.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  # target 'RunnerTests' do
  #   inherit! :search_paths
  # end
end

target 'TodayTasksWidgetExtension' do
  use_frameworks! :linkage => :static
  use_modular_headers!
  pod 'home_widget', :path => '.symlinks/plugins/home_widget/ios'
end

post_install do |installer|
  # Flutter.xcframeworkのパスを取得
  flutter_engine_dir = File.join(flutter_root, 'bin', 'cache', 'artifacts', 'engine')
  debug_xcframework = File.join(flutter_engine_dir, 'ios', 'Flutter.xcframework')
  release_xcframework = File.join(flutter_engine_dir, 'ios-release', 'Flutter.xcframework')

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
      # Firebaseの設定を追加
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_NOTIFICATIONS=1',
        'COCOAPODS=1',
      ]
    end
  end

  # ウィジェットExtension用: Flutter.xcframeworkのリンク設定をxcconfigに直接追加
  widget_xcconfig_dir = File.join(installer.sandbox.root, 'Target Support Files', 'Pods-TodayTasksWidgetExtension')
  Dir.glob("#{widget_xcconfig_dir}/*.xcconfig").each do |xcconfig_path|
    content = File.read(xcconfig_path)
    is_debug = xcconfig_path.include?('debug')
    framework_dir = is_debug ? debug_xcframework : release_xcframework
    sim_dir = Dir.glob("#{framework_dir}/ios-*-simulator").first
    device_dir = Dir.glob("#{framework_dir}/ios-arm64").first

    # FRAMEWORK_SEARCH_PATHSにFlutter.xcframeworkのパスを追加
    if sim_dir && !content.include?(sim_dir)
      content.gsub!(/^(FRAMEWORK_SEARCH_PATHS = .*)$/, "\\1 \"#{sim_dir}\"")
    end
    # OTHER_LDFLAGSに-framework Flutterを追加
    unless content.include?('-framework "Flutter"') || content.include?('-framework Flutter')
      content.gsub!(/^(OTHER_LDFLAGS = .*)$/, '\\1 -framework "Flutter"')
    end
    File.write(xcconfig_path, content)
  end
end
